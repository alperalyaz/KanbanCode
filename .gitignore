logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# TypeScript
*.tsbuildinfo

.pnpm-store/
/package-lock.json
notification_example/
temp/
.claude/


eslint-fix/
.eslintcache
.eslintcache-fast
remotion/*

.home/
.board-task-log-freshness/

